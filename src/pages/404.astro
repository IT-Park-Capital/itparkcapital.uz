---
import Base from '~/layouts/Base.astro';
import Icon from '~/components/Icon.astro';
import { localePath } from '~/i18n';
---
<Base title="404 — IT Park Capital" description="Page not found" locale="uz">
  <section class="container-page py-24 md:py-40 grid place-items-center text-center">
    <div class="max-w-xl">
      <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-100 text-brand-800 text-[12px] font-semibold tracking-[0.1em] uppercase">
        404
      </span>
      <h1 class="mt-6 text-[2.5rem] md:text-[3.5rem] font-semibold tracking-[-0.025em] leading-[1.05] text-ink-950">
        Sahifa topilmadi
      </h1>
      <p class="mt-5 text-[1.0625rem] text-ink-500 leading-relaxed">
        Siz qidirayotgan sahifa o'chirilgan, ko'chirilgan yoki mavjud emas. Bosh sahifaga qaytishingiz yoki dasturlar ro'yxatini ko'rishingiz mumkin.
      </p>
      <div class="mt-9 flex flex-wrap justify-center gap-3">
        <a href={localePath('uz')} class="btn btn-primary">
          Bosh sahifa
          <Icon name="arrow-right" class="h-4 w-4" />
        </a>
        <a href={localePath('uz', 'contact')} class="btn btn-outline">Aloqa</a>
      </div>
    </div>
  </section>
</Base>
