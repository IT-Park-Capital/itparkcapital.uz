---
import { localePath, type Locale } from '~/i18n';
import { programsOrdered } from '~/data/programs';
import Logo from '~/components/Logo.astro';
import Icon from '~/components/Icon.astro';

interface Props {
  locale: Locale;
  dict: any;
}

const { locale, dict } = Astro.props;
const programs = programsOrdered();
const year = new Date().getFullYear();
---

<footer class="border-t border-hairline bg-white mt-24 md:mt-32">
  <div class="container-page py-14 md:py-20">
    <div class="grid gap-12 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <Logo />
        <p class="mt-5 text-[15px] leading-relaxed text-ink-500 max-w-md">
          {dict.footer.tagline}
        </p>
        <div class="mt-7 flex flex-wrap gap-2.5">
          <a href="mailto:info@itparkcapital.uz" class="inline-flex items-center gap-2 px-3.5 py-2 rounded-lg border border-hairline text-[13.5px] text-ink-700 hover:border-ink-300 hover:text-ink-950 transition">
            <Icon name="mail" class="h-4 w-4" />
            info@itparkcapital.uz
          </a>
          <a href="tel:+998555151199" class="inline-flex items-center gap-2 px-3.5 py-2 rounded-lg border border-hairline text-[13.5px] text-ink-700 hover:border-ink-300 hover:text-ink-950 transition">
            <Icon name="phone" class="h-4 w-4" />
            +998 55 515 11 99
          </a>
        </div>
      </div>

      <div class="lg:col-span-3">
        <h4 class="text-[12px] font-semibold tracking-[0.12em] uppercase text-ink-400">
          {dict.footer.programsTitle}
        </h4>
        <ul class="mt-5 space-y-3">
          {programs.map((p) => (
            <li>
              <a href={localePath(locale, `programs/${p.slug}`)} class="text-[14.5px] text-ink-700 hover:text-brand-700 transition">
                {p.content[locale].shortTitle}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="lg:col-span-2">
        <h4 class="text-[12px] font-semibold tracking-[0.12em] uppercase text-ink-400">
          {dict.footer.companyTitle}
        </h4>
        <ul class="mt-5 space-y-3">
          <li><a href={localePath(locale, 'about')} class="text-[14.5px] text-ink-700 hover:text-brand-700 transition">{dict.footer.aboutLink}</a></li>
          <li><a href={localePath(locale, 'news')} class="text-[14.5px] text-ink-700 hover:text-brand-700 transition">{dict.footer.newsLink}</a></li>
          <li><a href={localePath(locale, 'contact')} class="text-[14.5px] text-ink-700 hover:text-brand-700 transition">{dict.footer.contactLink}</a></li>
        </ul>
      </div>

      <div class="lg:col-span-2">
        <h4 class="text-[12px] font-semibold tracking-[0.12em] uppercase text-ink-400">
          {dict.footer.contactTitle}
        </h4>
        <ul class="mt-5 space-y-3 text-[14px] text-ink-600">
          <li class="flex gap-2.5">
            <Icon name="pin" class="h-4 w-4 mt-0.5 shrink-0 text-ink-400" />
            <span>{dict.contact.address}</span>
          </li>
          <li class="flex gap-2.5">
            <Icon name="clock" class="h-4 w-4 mt-0.5 shrink-0 text-ink-400" />
            <span>{dict.contact.hours}</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-14 pt-8 border-t border-hairline flex flex-col md:flex-row md:items-center md:justify-between gap-6 text-[13px] text-ink-400">
      <span>© {year} IT Park Capital. {dict.footer.rights}</span>
      <div class="flex items-center gap-2.5 order-last md:order-none">
        <a href="https://t.me/itparkcapital" target="_blank" rel="noopener noreferrer" aria-label="Telegram" class="social-icon">
          <Icon name="telegram" class="h-4 w-4" />
        </a>
        <a href="https://www.instagram.com/itparkcapital/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-icon">
          <Icon name="instagram" class="h-4 w-4" />
        </a>
        <a href="https://www.facebook.com/share/1EHqyKS1nE/?mibextid=wwXIfr" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="social-icon">
          <Icon name="facebook" class="h-4 w-4" />
        </a>
        <a href="https://www.linkedin.com/company/itparkcapital/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-icon">
          <Icon name="linkedin" class="h-4 w-4" />
        </a>
        <a href="https://youtube.com/@itparkcapital" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="social-icon">
          <Icon name="youtube" class="h-4 w-4" />
        </a>
      </div>
      <div class="flex items-center gap-5">
        <a href="#" class="hover:text-ink-700 transition">{dict.footer.privacy}</a>
        <a href="#" class="hover:text-ink-700 transition">{dict.footer.terms}</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 9999px;
    border: 1px solid var(--color-hairline);
    color: var(--color-ink-500, #5b6573);
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }
  .social-icon:hover {
    color: var(--color-brand-700, #1e3a8a);
    border-color: var(--color-ink-300, #c7ccd3);
    background: rgba(4, 14, 30, 0.02);
    transform: translateY(-1px);
  }
</style>
