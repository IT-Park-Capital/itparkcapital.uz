---
import { type Locale, getDict } from '~/i18n';
import { ABOUT } from '~/data/about';
import Base from '~/layouts/Base.astro';
import CtaBanner from '~/components/CtaBanner.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDict(locale);
const about = ABOUT[locale];

const pillars = locale === 'uz' ? [
  { tag: "Moliyalashtirish", title: "Maqsadli qarz va davlat dasturlari", body: "IT-kompaniyalar uchun imtiyozli stavkalarda kreditlar va Zero Risk dasturi orqali to'g'ridan-to'g'ri kompensatsiyalar." },
  { tag: "Ekspertiza", title: "M&A va moliyaviy konsalting", body: "Bitimlarda baholash, tayyorgarlik, investor topish va muzokaralarni qo'llab-quvvatlash." },
  { tag: "Ta'lim", title: "Bilgi va Pearson VUE markazi", body: "100+ o'quv markazlari va xalqaro sertifikatsiya orqali kadrlar oqimini shakllantirish." },
] : locale === 'ru' ? [
  { tag: "Финансирование", title: "Целевые займы и госпрограммы", body: "Льготные кредиты для IT-компаний и прямые компенсации через программу Zero Risk." },
  { tag: "Экспертиза", title: "M&A и финансовые консультации", body: "Оценка, подготовка к сделкам, поиск инвесторов и сопровождение переговоров." },
  { tag: "Образование", title: "Bilgi и центр Pearson VUE", body: "100+ учебных центров и международная сертификация для устойчивого потока кадров." },
] : [
  { tag: "Financing", title: "Targeted loans & government programmes", body: "Concessional loans for IT companies and direct subsidies via the Zero Risk programme." },
  { tag: "Expertise", title: "M&A and financial advisory", body: "Valuation, preparation, investor search, and negotiation support throughout the deal." },
  { tag: "Education", title: "Bilgi and Pearson VUE centre", body: "100+ training centres and international certification for a sustainable talent pipeline." },
];
---

<Base title={`${dict.nav.about} — IT Park Capital`} description={about.lead} locale={locale}>
  {/* HERO */}
  <section class="about-hero">
    <div class="container-page">
      <div class="about-hero-pill reveal">
        <span class="about-hero-pill-dot" aria-hidden="true"></span>
        <span>{dict.about.establishedPill}</span>
      </div>

      <h1 class="about-hero-title reveal" style="transition-delay: 60ms">
        {about.title}
      </h1>

      <p class="about-hero-lead reveal" style="transition-delay: 140ms">
        {about.lead}
      </p>
    </div>
  </section>

  {/* PILLARS — numbered editorial cards */}
  <section class="container-page py-20 md:py-28">
    <div class="grid gap-10 lg:gap-16 lg:grid-cols-12 mb-12 md:mb-16">
      <div class="lg:col-span-5 reveal">
        <span class="section-tag">{dict.about.pillarsTitle}</span>
        <h2 class="mt-4 text-[1.875rem] md:text-[2.5rem] font-semibold tracking-[-0.025em] leading-[1.05] text-ink-950">
          {dict.about.sectionTitle}
        </h2>
      </div>
      <div class="lg:col-span-7 reveal" style="transition-delay: 80ms">
        <p class="text-[1.0625rem] md:text-[1.125rem] leading-[1.6] text-ink-500 max-w-2xl">
          {dict.about.pillarsSubtitle}
        </p>
      </div>
    </div>

    <div class="pillars">
      {pillars.map((p, i) => (
        <article class="pillar reveal" style={`transition-delay: ${i * 80}ms`}>
          <div class="pillar-num">0{i + 1}</div>
          <span class="pillar-tag">{p.tag}</span>
          <h3 class="pillar-title">{p.title}</h3>
          <p class="pillar-body">{p.body}</p>
        </article>
      ))}
    </div>
  </section>

  {/* MISSION — editorial pull quote */}
  <section class="container-page py-16 md:py-24">
    <div class="mission-block reveal">
      <span class="mission-eyebrow">
        <span class="mission-eyebrow-bar" aria-hidden="true"></span>
        {dict.about.missionEyebrow}
      </span>
      <span class="mission-quote-mark" aria-hidden="true">"</span>
      <p class="mission-text">{about.mission}</p>
      <span class="mission-sign">{dict.about.missionSign}</span>
    </div>
  </section>

  {/* TIMELINE / STORY */}
  <section class="container-page py-16 md:py-24">
    <div class="grid gap-10 lg:gap-16 lg:grid-cols-12 mb-10 md:mb-14">
      <div class="lg:col-span-5 reveal">
        <span class="section-tag">{dict.about.storyEyebrow}</span>
        <h2 class="mt-4 text-[1.875rem] md:text-[2.5rem] font-semibold tracking-[-0.025em] leading-[1.05] text-ink-950">
          {dict.about.timelineTitle}
        </h2>
      </div>
      <div class="lg:col-span-7 reveal" style="transition-delay: 80ms">
        <p class="text-[1.0625rem] md:text-[1.125rem] leading-[1.6] text-ink-500 max-w-2xl">
          {dict.about.timelineSubtitle}
        </p>
      </div>
    </div>

    <ol class="timeline">
      {about.timeline.map((entry, i) => (
        <li class="timeline-item reveal" style={`transition-delay: ${i * 90}ms`}>
          <div class="timeline-marker" aria-hidden="true">
            <span class="timeline-dot"></span>
          </div>
          <div class="timeline-year">
            <span class="tabular-nums">{entry.year}</span>
          </div>
          <div class="timeline-content">
            <h3 class="timeline-title">{entry.title}</h3>
            <p class="timeline-body">{entry.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <CtaBanner locale={locale} dict={dict} variant="compact" />
</Base>

<style>
  /* ============ HERO ============ */
  .about-hero {
    padding-top: 3.5rem;
    padding-bottom: 4rem;
    background:
      radial-gradient(ellipse 800px 400px at 90% 0%, rgba(133, 188, 50, 0.06), transparent 65%),
      linear-gradient(180deg, var(--color-canvas) 0%, transparent 100%);
    border-bottom: 1px solid var(--color-hairline);
  }
  @media (min-width: 768px) {
    .about-hero { padding-top: 5rem; padding-bottom: 5.5rem; }
  }

  .about-hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem 0.375rem 0.625rem;
    border-radius: 999px;
    background: white;
    border: 1px solid var(--color-hairline);
    font-size: 12px;
    font-weight: 500;
    color: var(--color-ink-700);
    letter-spacing: 0.005em;
    box-shadow: 0 1px 2px rgba(4, 14, 30, 0.03);
  }
  .about-hero-pill-dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--color-brand-500);
  }

  .about-hero-title {
    margin-top: 1.75rem;
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 600;
    letter-spacing: -0.028em;
    line-height: 1.04;
    color: var(--color-ink-950);
    max-width: 18ch;
  }

  .about-hero-lead {
    margin-top: 1.5rem;
    font-size: clamp(1.0625rem, 1.6vw, 1.25rem);
    font-weight: 400;
    letter-spacing: -0.005em;
    line-height: 1.55;
    color: var(--color-ink-600);
    max-width: 56ch;
  }

  /* ============ PILLARS ============ */
  .pillars {
    display: grid;
    gap: 1px;
    background: var(--color-hairline);
    border: 1px solid var(--color-hairline);
    border-radius: 18px;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .pillars { grid-template-columns: repeat(3, 1fr); }
  }
  .pillar {
    position: relative;
    padding: 2rem 1.75rem 2.25rem;
    background: white;
    transition: background 0.25s ease;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .pillar:hover { background: var(--color-canvas); }

  .pillar-num {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    font-size: 60px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-ink-100);
    font-variant-numeric: tabular-nums;
    transition: color 0.25s ease;
    pointer-events: none;
    user-select: none;
  }
  .pillar:hover .pillar-num {
    color: var(--color-brand-200);
  }

  .pillar-tag {
    position: relative;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-brand-700);
  }

  .pillar-title {
    margin-top: 0.875rem;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.012em;
    line-height: 1.3;
    color: var(--color-ink-950);
    max-width: 22ch;
  }
  .pillar-body {
    margin-top: 0.625rem;
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-ink-500);
  }

  /* ============ MISSION ============ */
  .mission-block {
    position: relative;
    max-width: 820px;
    margin: 0 auto;
    padding: 3rem 0;
    text-align: left;
  }

  .mission-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-brand-700);
    margin-bottom: 2rem;
  }
  .mission-eyebrow-bar {
    display: inline-block;
    width: 18px;
    height: 1px;
    background: var(--color-brand-500);
  }

  .mission-quote-mark {
    position: absolute;
    top: 1.75rem;
    left: -2.5rem;
    font-size: 120px;
    font-weight: 700;
    line-height: 0.8;
    color: var(--color-brand-200);
    user-select: none;
    pointer-events: none;
    font-family: Georgia, "Times New Roman", serif;
  }
  @media (max-width: 900px) {
    .mission-quote-mark { display: none; }
  }

  .mission-text {
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    font-weight: 400;
    letter-spacing: -0.012em;
    line-height: 1.5;
    color: var(--color-ink-800);
  }

  .mission-sign {
    display: block;
    margin-top: 2rem;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-ink-500);
    letter-spacing: 0.02em;
  }

  /* ============ TIMELINE ============ */
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
  }
  .timeline-item {
    position: relative;
    display: grid;
    grid-template-columns: 24px 96px 1fr;
    gap: 1.25rem;
    padding: 1.75rem 0;
    border-top: 1px solid var(--color-hairline);
  }
  .timeline-item:last-child {
    border-bottom: 1px solid var(--color-hairline);
  }
  @media (max-width: 640px) {
    .timeline-item {
      grid-template-columns: 24px 1fr;
      gap: 0.875rem;
    }
  }

  .timeline-marker {
    position: relative;
    grid-column: 1;
    padding-top: 6px;
  }
  .timeline-marker::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 100%;
    background: var(--color-hairline);
  }
  .timeline-item:first-child .timeline-marker::before { top: -6px; }

  .timeline-dot {
    position: relative;
    z-index: 1;
    display: block;
    width: 12px;
    height: 12px;
    border-radius: 999px;
    background: white;
    border: 2px solid var(--color-brand-500);
    box-shadow: 0 0 0 4px white;
    margin: 0 auto;
    transition: background 0.25s ease, transform 0.25s ease;
  }
  .timeline-item:hover .timeline-dot {
    background: var(--color-brand-500);
    transform: scale(1.1);
  }

  .timeline-year {
    grid-column: 2;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-brand-700);
    letter-spacing: 0.02em;
    padding-top: 4px;
    font-variant-numeric: tabular-nums;
  }
  @media (max-width: 640px) {
    .timeline-year {
      grid-column: 2;
      font-size: 12px;
      padding-top: 2px;
    }
    .timeline-content { grid-column: 2; }
  }

  .timeline-content {
    grid-column: 3;
    max-width: 720px;
  }
  @media (max-width: 640px) {
    .timeline-year { display: block; margin-bottom: 0.375rem; }
    .timeline-content { grid-column: 2; }
  }

  .timeline-title {
    font-size: 17px;
    font-weight: 600;
    color: var(--color-ink-950);
    letter-spacing: -0.012em;
    line-height: 1.3;
  }
  .timeline-body {
    margin-top: 0.5rem;
    font-size: 14.5px;
    line-height: 1.65;
    color: var(--color-ink-500);
  }
</style>
