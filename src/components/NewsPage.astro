---
import { type Locale, getDict, localePath } from '~/i18n';
import Base from '~/layouts/Base.astro';
import Icon from '~/components/Icon.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDict(locale);

const dateLocale = locale === 'uz' ? 'uz-UZ' : locale === 'ru' ? 'ru-RU' : 'en-GB';
const detailBase = localePath(locale, 'news/view');

const labels = {
  readMore: dict.news.readMore,
  empty: dict.news.empty,
  all: dict.news.categories.all,
};

const newsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: dict.news.heroTitle,
  description: dict.news.heroSubtitle,
  inLanguage: locale === 'uz' ? 'uz-UZ' : locale === 'ru' ? 'ru-RU' : 'en-US',
};
---

<Base
  title={`${dict.news.heroTitle} — IT Park Capital`}
  description={dict.news.heroSubtitle}
  locale={locale}
  jsonLd={newsJsonLd}
>
  <div class="news-page">
    {/* HERO */}
    <section class="news-hero">
      <div class="container-page">
        <span class="news-hero-eyebrow reveal">
          <span class="news-hero-eyebrow-bar" aria-hidden="true"></span>
          {dict.news.heroEyebrow}
        </span>
        <h1 class="news-hero-title reveal" style="transition-delay: 60ms">
          {dict.news.heroTitle}
        </h1>
        <p class="news-hero-lead reveal" style="transition-delay: 140ms">
          {dict.news.heroSubtitle}
        </p>
      </div>
    </section>

    {/* CATEGORIES + LIST (rendered client-side from the CMS API) */}
    <section
      id="news-root"
      class="container-page py-12 md:py-16"
      data-locale={locale}
      data-date-locale={dateLocale}
      data-detail-base={detailBase}
      data-labels={JSON.stringify(labels)}
    >
      <div id="news-filter" class="news-filter" role="tablist" aria-label={dict.news.categories.all} hidden></div>

      <div id="news-loading" class="news-loading">
        <span class="news-spinner" aria-hidden="true"></span>
      </div>

      <div id="news-grid" class="news-grid"></div>

      <div id="news-empty" class="news-empty" hidden>
        <Icon name="newspaper" class="h-7 w-7 text-ink-300" />
        <p>{dict.news.empty}</p>
      </div>
    </section>
  </div>
</Base>

{/*
  Styles are global (is:global) but namespaced under .news-page, because the cards
  and filter chips are created in the client <script> below — Astro's default scoped
  styles only attach to server-rendered elements and would not reach them.
*/}
<style is:global>
  .news-page .news-hero {
    padding-top: 3.5rem;
    padding-bottom: 1rem;
    background:
      radial-gradient(ellipse 800px 400px at 90% 0%, rgba(133, 188, 50, 0.06), transparent 65%),
      linear-gradient(180deg, var(--color-canvas) 0%, transparent 100%);
  }
  @media (min-width: 768px) {
    .news-page .news-hero { padding-top: 5rem; padding-bottom: 1.5rem; }
  }

  .news-page .news-hero-eyebrow {
    display: inline-flex; align-items: center; gap: 0.625rem;
    font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.14em;
    color: var(--color-brand-700);
  }
  .news-page .news-hero-eyebrow-bar { display: inline-block; width: 18px; height: 1px; background: var(--color-brand-500); }

  .news-page .news-hero-title {
    margin-top: 1.5rem;
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 600; letter-spacing: -0.028em; line-height: 1.04;
    color: var(--color-ink-950); max-width: 22ch;
  }
  .news-page .news-hero-lead {
    margin-top: 1.25rem;
    font-size: clamp(1.0625rem, 1.6vw, 1.25rem);
    line-height: 1.55; color: var(--color-ink-600); max-width: 60ch;
  }

  /* === Filter === */
  .news-page .news-filter { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; }
  .news-page .news-filter-chip {
    display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0.875rem;
    background: white; border: 1px solid var(--color-hairline); border-radius: 999px;
    font-family: inherit; font-size: 13.5px; font-weight: 500; color: var(--color-ink-600);
    cursor: pointer; transition: color 0.18s ease, border-color 0.18s ease, background 0.18s ease;
  }
  .news-page .news-filter-chip:hover { border-color: var(--color-edge); color: var(--color-ink-950); }
  .news-page .news-filter-chip[data-active='true'] { background: var(--color-ink-950); border-color: var(--color-ink-950); color: white; }
  .news-page .news-filter-count {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 20px; height: 18px; padding: 0 6px; border-radius: 999px;
    background: var(--color-canvas); color: var(--color-ink-500);
    font-size: 11.5px; font-weight: 600; line-height: 1;
  }
  .news-page .news-filter-chip[data-active='true'] .news-filter-count { background: rgba(255, 255, 255, 0.18); color: white; }

  /* === Grid === */
  .news-page .news-grid { display: grid; gap: 1.5rem; grid-template-columns: 1fr; }
  @media (min-width: 640px) { .news-page .news-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .news-page .news-grid { grid-template-columns: repeat(3, 1fr); gap: 1.75rem; } }

  /* === Card === */
  .news-page .news-card {
    display: flex; flex-direction: column; background: white;
    border: 1px solid var(--color-hairline); border-radius: 18px; overflow: hidden;
    box-shadow: 0 1px 3px rgba(4, 14, 30, 0.04), 0 12px 28px -20px rgba(4, 14, 30, 0.12);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .news-page .news-card:hover {
    border-color: var(--color-edge); transform: translateY(-3px);
    box-shadow: 0 1px 3px rgba(4, 14, 30, 0.05), 0 20px 40px -22px rgba(4, 14, 30, 0.18);
  }
  .news-page .news-card[hidden] { display: none; }

  /* Uniform main photo — same 16:9 box for every card, cropped to fill. */
  .news-page .news-card-imagelink { display: block; }
  .news-page .news-card-image {
    display: block; width: 100%; aspect-ratio: 16 / 9; object-fit: cover;
    border-top-left-radius: 18px; border-top-right-radius: 18px; background: var(--color-canvas);
    opacity: 0; transition: opacity 0.45s ease;
  }
  .news-page .news-card-image.is-loaded { opacity: 1; }

  /* Image loading skeleton (shimmer) */
  .news-page .news-skeleton { position: relative; overflow: hidden; background-color: var(--color-hairline); }
  .news-page .news-skeleton::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.7), transparent);
    transform: translateX(-100%); animation: news-shimmer 1.3s infinite;
  }
  @keyframes news-shimmer { 100% { transform: translateX(100%); } }

  .news-page .news-card-body { display: flex; flex-direction: column; flex: 1; padding: 1.5rem; }
  @media (min-width: 768px) { .news-page .news-card-body { padding: 1.75rem; } }

  .news-page .news-card-meta { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; margin-bottom: 1.1rem; }
  .news-page .news-card-cat {
    display: inline-flex; align-items: center; padding: 0.25rem 0.625rem; border-radius: 999px;
    font-size: 11px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;
    background: var(--color-canvas); color: var(--color-ink-700); white-space: nowrap;
  }
  .news-page .news-card-date {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-size: 12.5px; font-weight: 500; color: var(--color-ink-400);
    font-variant-numeric: tabular-nums; white-space: nowrap;
  }

  .news-page .news-card-title {
    font-size: 1.25rem; font-weight: 700; color: var(--color-ink-950);
    letter-spacing: -0.015em; line-height: 1.3;
  }
  @media (min-width: 768px) { .news-page .news-card-title { font-size: 1.3125rem; } }
  .news-page .news-card-summary { margin-top: 0.8rem; font-size: 14.5px; color: var(--color-ink-500); line-height: 1.6; flex: 1; }
  .news-page .news-card-link {
    display: inline-flex; align-items: center; gap: 0.4rem; margin-top: 1.5rem; padding-top: 1.1rem;
    border-top: 1px solid var(--color-hairline); font-size: 13.5px; font-weight: 600;
    color: var(--color-ink-950); text-decoration: none; transition: color 0.18s ease;
  }
  .news-page .news-card-link:hover { color: var(--color-brand-700); }
  .news-page .news-card-arrow { transition: transform 0.18s ease; }
  .news-page .news-card-link:hover .news-card-arrow { transform: translateX(3px); }

  /* === Loading / Empty === */
  .news-page .news-loading { display: flex; justify-content: center; padding: 3rem 0; }
  .news-page .news-spinner {
    width: 28px; height: 28px; border-radius: 50%;
    border: 3px solid var(--color-hairline); border-top-color: var(--color-brand-500);
    animation: news-spin 0.7s linear infinite;
  }
  @keyframes news-spin { to { transform: rotate(360deg); } }
  .news-page .news-empty {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 0.75rem; padding: 4rem 1.5rem; background: white; border: 1px dashed var(--color-hairline);
    border-radius: 16px; color: var(--color-ink-500); font-size: 15px;
  }
</style>

<script>
  import { fetchNews, fetchCategories, type PublicNewsListItem, type PublicNewsCategory } from '~/lib/news.api';
  import { loadImage } from '~/lib/skeleton-image';

  const ARROW_SVG =
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="news-card-arrow" width="14" height="14"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>';
  const CAL_SVG =
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" width="14" height="14"><rect x="3" y="4.5" width="18" height="16" rx="2"/><path d="M3 9h18M8 2.5v4M16 2.5v4" stroke-linecap="round"/></svg>';

  const HEX6 = /^#([0-9a-f]{6})$/i;
  const UZ_MONTHS = ['yanvar', 'fevral', 'mart', 'aprel', 'may', 'iyun', 'iyul', 'avgust', 'sentabr', 'oktabr', 'noyabr', 'dekabr'];

  function init() {
    const root = document.getElementById('news-root');
    const grid = document.getElementById('news-grid');
    const filter = document.getElementById('news-filter');
    const loading = document.getElementById('news-loading');
    const empty = document.getElementById('news-empty');
    if (!root || !grid || !filter || !loading || !empty) return;

    const locale = root.dataset.locale || 'uz';
    const dateLocale = root.dataset.dateLocale || 'uz-UZ';
    const detailBase = root.dataset.detailBase || '/news/view';
    const labels = JSON.parse(root.dataset.labels || '{}') as { readMore: string; empty: string; all: string };

    const formatDate = (iso: string) => {
      const d = new Date(iso);
      if (locale === 'uz') return `${d.getDate()}-${UZ_MONTHS[d.getMonth()]}, ${d.getFullYear()}`;
      return d.toLocaleDateString(dateLocale, { day: 'numeric', month: 'long', year: 'numeric' });
    };

    const detailHref = (slug: string) => `${detailBase}?slug=${encodeURIComponent(slug)}`;

    function applyCatColor(el: HTMLElement, color: string | null) {
      if (color && HEX6.test(color)) {
        el.style.background = `${color}22`;
        el.style.color = color;
      }
    }

    function renderCard(item: PublicNewsListItem): HTMLElement {
      const article = document.createElement('article');
      article.className = 'news-card';
      article.dataset.category = item.categorySlug ?? '';

      if (item.mainImageUrl) {
        const a = document.createElement('a');
        a.className = 'news-card-imagelink';
        a.href = detailHref(item.slug);
        article.appendChild(a);
        // Shimmer skeleton until the photo loads; drop it gracefully on error → clean text card.
        loadImage(a, 'news-card-image', item.mainImageUrl, item.title, () => a.remove());
      }

      const body = document.createElement('div');
      body.className = 'news-card-body';

      const meta = document.createElement('div');
      meta.className = 'news-card-meta';

      if (item.categoryName) {
        const cat = document.createElement('span');
        cat.className = 'news-card-cat';
        cat.textContent = item.categoryName;
        applyCatColor(cat, item.categoryColor);
        meta.appendChild(cat);
      } else {
        meta.appendChild(document.createElement('span'));
      }

      const date = document.createElement('span');
      date.className = 'news-card-date';
      date.innerHTML = CAL_SVG;
      date.appendChild(document.createTextNode(' ' + formatDate(item.publishedAt)));
      meta.appendChild(date);
      body.appendChild(meta);

      const title = document.createElement('h3');
      title.className = 'news-card-title';
      title.textContent = item.title;
      body.appendChild(title);

      if (item.subtitle) {
        const summary = document.createElement('p');
        summary.className = 'news-card-summary';
        summary.textContent = item.subtitle;
        body.appendChild(summary);
      }

      const link = document.createElement('a');
      link.className = 'news-card-link';
      link.href = detailHref(item.slug);
      link.setAttribute('aria-label', `${labels.readMore}: ${item.title}`);
      link.appendChild(document.createTextNode(labels.readMore + ' '));
      const arrow = document.createElement('span');
      arrow.innerHTML = ARROW_SVG;
      link.appendChild(arrow.firstChild as Node);
      body.appendChild(link);

      article.appendChild(body);
      return article;
    }

    function renderFilter(items: PublicNewsListItem[], categories: PublicNewsCategory[]) {
      const counts = new Map<string, number>();
      for (const n of items) {
        if (n.categorySlug) counts.set(n.categorySlug, (counts.get(n.categorySlug) ?? 0) + 1);
      }
      const used = categories.filter(c => (counts.get(c.slug) ?? 0) > 0);
      if (used.length === 0) return;

      const chips: { key: string; label: string; count: number }[] = [
        { key: 'all', label: labels.all, count: items.length },
        ...used.map(c => ({ key: c.slug, label: c.name || c.slug, count: counts.get(c.slug) ?? 0 })),
      ];

      filter!.innerHTML = '';
      chips.forEach((c, i) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'news-filter-chip';
        btn.dataset.filter = c.key;
        btn.dataset.active = i === 0 ? 'true' : 'false';
        btn.setAttribute('role', 'tab');
        const label = document.createElement('span');
        label.textContent = c.label;
        const count = document.createElement('span');
        count.className = 'news-filter-count';
        count.textContent = String(c.count);
        btn.append(label, count);
        filter!.appendChild(btn);
      });
      filter!.hidden = false;

      filter!.querySelectorAll<HTMLButtonElement>('.news-filter-chip').forEach(chip => {
        chip.addEventListener('click', () => {
          const target = chip.dataset.filter;
          filter!.querySelectorAll<HTMLButtonElement>('.news-filter-chip')
            .forEach(c => c.setAttribute('data-active', c === chip ? 'true' : 'false'));
          grid!.querySelectorAll<HTMLElement>('.news-card').forEach(card => {
            card.hidden = target !== 'all' && card.dataset.category !== target;
          });
        });
      });
    }

    Promise.all([fetchNews(locale), fetchCategories(locale)])
      .then(([items, categories]) => {
        loading!.hidden = true;
        if (!items.length) {
          empty!.hidden = false;
          return;
        }
        const frag = document.createDocumentFragment();
        items.forEach(item => frag.appendChild(renderCard(item)));
        grid!.appendChild(frag);
        renderFilter(items, categories);
      })
      .catch(() => {
        loading!.hidden = true;
        empty!.hidden = false;
      });
  }

  init();
</script>
