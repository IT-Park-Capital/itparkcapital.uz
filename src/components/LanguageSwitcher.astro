---
import { alternates, type Locale } from '~/i18n';
import Icon from '~/components/Icon.astro';

interface Props {
  locale: Locale;
  pathname: string;
  dict: { lang: { current: string; uz: string; ru: string; en: string } };
}

const { locale, pathname, dict } = Astro.props;
const altMap = alternates(pathname);
const order: Locale[] = ['uz', 'ru', 'en'];
---

<div class="lang-switcher relative">
  <button
    type="button"
    class="lang-trigger"
    aria-haspopup="listbox"
    aria-expanded="false"
  >
    <span>{dict.lang[locale]}</span>
    <Icon name="chevron-down" class="h-3 w-3 lang-chevron" />
  </button>
  <div class="lang-menu" role="listbox">
    {order.map((l) => (
      <a
        href={altMap[l]}
        class={`lang-option ${l === locale ? 'is-active' : ''}`}
        hreflang={l}
        role="option"
        aria-selected={l === locale}
      >
        <span>{dict.lang[l]}</span>
        {l === locale && <Icon name="check" class="h-3.5 w-3.5" strokeWidth={2.2} />}
      </a>
    ))}
  </div>
</div>

<style>
  .lang-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    height: 36px;
    padding: 0 0.625rem;
    border-radius: 8px;
    background: transparent;
    border: 0;
    color: var(--color-ink-600);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: color 0.18s ease, background 0.18s ease;
    font-family: inherit;
  }
  .lang-trigger:hover {
    color: var(--color-ink-950);
    background: var(--color-canvas);
  }
  .lang-trigger[aria-expanded='true'] {
    color: var(--color-ink-950);
    background: var(--color-canvas);
  }
  .lang-chevron {
    opacity: 0.55;
    transition: transform 0.22s ease, opacity 0.18s ease;
  }
  .lang-trigger:hover .lang-chevron { opacity: 0.9; }
  .lang-trigger[aria-expanded='true'] .lang-chevron {
    transform: rotate(180deg);
    opacity: 0.9;
  }

  .lang-menu {
    position: absolute;
    right: 0;
    top: calc(100% + 6px);
    min-width: 152px;
    padding: 4px;
    background: white;
    border: 1px solid var(--color-hairline);
    border-radius: 12px;
    box-shadow: 0 12px 28px -8px rgba(4, 14, 30, 0.12), 0 4px 8px rgba(4, 14, 30, 0.04);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-4px);
    transition: opacity 0.18s ease, transform 0.22s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 50;
  }
  .lang-menu.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .lang-option {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.625rem;
    padding: 0.5rem 0.625rem 0.5rem 0.75rem;
    border-radius: 8px;
    font-size: 13.5px;
    color: var(--color-ink-700);
    text-decoration: none;
    transition: background 0.16s ease, color 0.16s ease;
  }
  .lang-option:hover {
    background: var(--color-canvas);
    color: var(--color-ink-950);
  }
  .lang-option.is-active {
    color: var(--color-ink-950);
    font-weight: 600;
  }
  .lang-option.is-active :global(svg) {
    color: var(--color-brand-600);
  }
</style>

<script>
  function initLang() {
    // Carry the current query string + hash onto the language links so switching
    // locale keeps the page state — e.g. the news detail page reads ?slug=...
    // (alternates() builds clean paths without the query).
    const suffix = window.location.search + window.location.hash;
    if (suffix) {
      document.querySelectorAll<HTMLAnchorElement>('.lang-option').forEach((a) => {
        const base = a.getAttribute('href') || '';
        if (!base.includes('?') && !base.includes('#')) a.setAttribute('href', base + suffix);
      });
    }

    document.querySelectorAll<HTMLElement>('.lang-switcher').forEach((root) => {
      if ((root as any).__bound) return;
      (root as any).__bound = true;
      const trigger = root.querySelector<HTMLButtonElement>('.lang-trigger');
      const menu = root.querySelector<HTMLElement>('.lang-menu');
      if (!trigger || !menu) return;

      const open = () => {
        menu.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
      };
      const close = () => {
        menu.classList.remove('is-open');
        trigger.setAttribute('aria-expanded', 'false');
      };
      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        isOpen ? close() : open();
      });
      document.addEventListener('click', (e) => {
        if (!root.contains(e.target as Node)) close();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });
    });
  }
  initLang();
</script>
