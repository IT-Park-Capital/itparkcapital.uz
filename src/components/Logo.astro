---
import { Image } from 'astro:assets';
import logoSrc from '~/assets/images/Logo.png';

interface Props {
  class?: string;
  height?: number;
}

const { class: className = '', height = 36 } = Astro.props;
---

<Image
  src={logoSrc}
  alt="IT Park Capital"
  height={height}
  widths={[120, 200, 320]}
  sizes="200px"
  loading="eager"
  decoding="async"
  class={`block w-auto ${className}`}
  style={`height: ${height}px;`}
/>
