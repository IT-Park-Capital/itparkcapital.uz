---
import { localePath, type Locale } from '~/i18n';
import { ABOUT } from '~/data/about';
import Icon from '~/components/Icon.astro';

interface Props {
  locale: Locale;
  dict: any;
}

const { locale, dict } = Astro.props;
const about = ABOUT[locale];
---

<section class="container-page py-16 md:py-24">
  <div class="grid gap-10 lg:gap-16 lg:grid-cols-12 items-start">
    <div class="lg:col-span-5 reveal">
      <span class="section-tag">{dict.about.sectionTag}</span>
      <h2 class="mt-4 text-[1.875rem] md:text-[2.5rem] font-semibold tracking-[-0.025em] leading-[1.1] text-ink-950">
        {dict.about.sectionTitle}
      </h2>
    </div>
    <div class="lg:col-span-7 reveal" style="transition-delay: 80ms">
      <p class="text-[1.125rem] md:text-[1.25rem] leading-[1.55] text-ink-950 font-medium tracking-[-0.005em]">
        {about.lead}
      </p>
      <p class="mt-6 text-[1rem] leading-[1.7] text-ink-500">
        {about.paragraphs[2] ?? about.paragraphs[0]}
      </p>
      <a href={localePath(locale, 'about')} class="inline-flex items-center gap-2 mt-8 text-[14.5px] font-medium text-ink-950 hover:text-brand-700 transition group">
        {dict.about.readMore}
        <span class="group-hover:translate-x-1 transition-transform inline-flex">
          <Icon name="arrow-right" class="h-4 w-4" />
        </span>
      </a>
    </div>
  </div>
</section>
