---
import { localePath, type Locale } from '~/i18n';
import { getProgram } from '~/data/programs';
import Icon from '~/components/Icon.astro';

interface Props {
  locale: Locale;
  dict: any;
}

const { locale, dict } = Astro.props;
const zeroRisk = getProgram('zero-risk').content[locale];
const bilgi = getProgram('bilgi').content[locale];

const zr = zeroRisk.kind === 'zero-risk' ? zeroRisk.results : [];
const bg = bilgi.kind === 'bilgi' ? bilgi.results : [];
---

<section class="container-page py-16 md:py-24">
  <div class="max-w-2xl reveal">
    <span class="section-tag">{dict.results.sectionTag}</span>
    <h2 class="mt-4 text-[1.875rem] md:text-[2.5rem] font-semibold tracking-[-0.025em] leading-[1.1] text-ink-950">
      {dict.results.sectionTitle}
    </h2>
    <p class="mt-4 text-[1.0625rem] leading-relaxed text-ink-500">
      {dict.results.sectionSubtitle}
    </p>
  </div>

  <div class="mt-12 grid gap-5 lg:grid-cols-12">
    <div class="lg:col-span-7 results-block results-block--dark p-7 md:p-10 reveal">
      <div class="flex items-center gap-3">
        <span class="grid place-items-center h-10 w-10 rounded-lg bg-brand-500/15 text-brand-400">
          <Icon name="shield" class="h-5 w-5" />
        </span>
        <div>
          <span class="block text-[12px] font-semibold tracking-[0.14em] uppercase text-white/50">
            {dict.programs.items['zero-risk'].tagline}
          </span>
          <span class="block text-[16px] font-semibold tracking-tight text-white">Zero Risk</span>
        </div>
      </div>
      <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 gap-y-7 gap-x-4">
        {zr.map((r) => (
          <div>
            <span class="block text-[26px] md:text-[32px] font-semibold tracking-[-0.02em] text-white leading-none" data-counter={r.value}>
              {r.value}
            </span>
            <span class="block mt-2 text-[12.5px] text-white/60 leading-snug">{r.label}</span>
          </div>
        ))}
      </div>
      <a href={localePath(locale, 'programs/zero-risk')} class="inline-flex items-center gap-1.5 mt-9 text-[14px] font-medium text-brand-400 hover:text-brand-300 transition group">
        {dict.programs.learnMore}
        <Icon name="arrow-right" class="h-3.5 w-3.5 group-hover:translate-x-1 transition-transform" />
      </a>
    </div>

    <div class="lg:col-span-5 results-block results-block--green p-7 md:p-10 reveal" style="transition-delay: 100ms">
      <div class="flex items-center gap-3">
        <span class="grid place-items-center h-10 w-10 rounded-lg bg-ink-950 text-brand-400">
          <Icon name="grid" class="h-5 w-5" />
        </span>
        <div>
          <span class="block text-[12px] font-semibold tracking-[0.14em] uppercase text-ink-950/60">
            {dict.programs.items['bilgi'].tagline}
          </span>
          <span class="block text-[16px] font-semibold tracking-tight text-ink-950">Bilgi</span>
        </div>
      </div>
      <div class="mt-8 grid grid-cols-2 gap-y-7 gap-x-4">
        {bg.slice(0, 4).map((r) => (
          <div>
            <span class="block text-[26px] md:text-[32px] font-semibold tracking-[-0.02em] text-ink-950 leading-none" data-counter={r.value}>
              {r.value}
            </span>
            <span class="block mt-2 text-[12.5px] text-ink-950/70 leading-snug">{r.label}</span>
          </div>
        ))}
      </div>
      <a href={localePath(locale, 'programs/bilgi')} class="inline-flex items-center gap-1.5 mt-9 text-[14px] font-medium text-ink-950 hover:opacity-70 transition group">
        {dict.programs.learnMore}
        <Icon name="arrow-right" class="h-3.5 w-3.5 group-hover:translate-x-1 transition-transform" />
      </a>
    </div>
  </div>
</section>

<style>
  .results-block {
    border-radius: 24px;
    overflow: hidden;
    position: relative;
  }

  .results-block--dark {
    background: linear-gradient(160deg, #1a2334 0%, #040e1e 100%);
    border: 1px solid rgba(133, 188, 50, 0.08);
  }

  .results-block--dark::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 400px 200px at 100% 0%, rgba(133, 188, 50, 0.16), transparent 70%);
    pointer-events: none;
  }

  .results-block--green {
    background: linear-gradient(160deg, #c8e8a4 0%, #85bc32 100%);
    box-shadow: 0 8px 32px rgba(133, 188, 50, 0.18);
  }
</style>
