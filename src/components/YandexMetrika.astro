---
/**
 * Yandex.Metrika counter. Rendered as high in <body> as possible, per Yandex's
 * install guide. Only emitted in production builds so local dev traffic and
 * `astro dev` reloads never reach the counter.
 */
const COUNTER_ID = 106892420;
const enabled = import.meta.env.PROD;
---

{enabled && (
  <Fragment>
    {/* Yandex.Metrika counter */}
    <script type="text/javascript" is:inline define:vars={{ COUNTER_ID }}>
      (function(m,e,t,r,i,k,a){
          m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
          m[i].l=1*new Date();
          for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
          k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
      })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=' + COUNTER_ID, 'ym');

      ym(COUNTER_ID, 'init', {ssr:true, webvisor:true, clickmap:true, ecommerce:"dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true});
    </script>
    <noscript><div><img src={`https://mc.yandex.ru/watch/${COUNTER_ID}`} style="position:absolute; left:-9999px;" alt="" /></div></noscript>
    {/* /Yandex.Metrika counter */}
  </Fragment>
)}
