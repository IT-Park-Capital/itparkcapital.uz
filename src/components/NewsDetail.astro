---
import { type Locale, getDict, localePath } from '~/i18n';
import Base from '~/layouts/Base.astro';
import Icon from '~/components/Icon.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDict(locale);

const dateLocale = locale === 'uz' ? 'uz-UZ' : locale === 'ru' ? 'ru-RU' : 'en-GB';
const newsBase = localePath(locale, 'news');

const labels = {
  backToNews: dict.news.backToNews,
  loadError: dict.news.loadError,
  published: dict.news.published,
};
---

<Base title={`${dict.news.heroTitle} — IT Park Capital`} description={dict.news.heroSubtitle} locale={locale}>
  <section
    id="news-detail-root"
    class="container-prose news-detail"
    data-lang={locale}
    data-date-locale={dateLocale}
    data-news-base={newsBase}
    data-labels={JSON.stringify(labels)}
  >
    <a href={newsBase} class="news-detail-back">
      <Icon name="arrow-left" class="h-4 w-4" />
      {dict.news.backToNews}
    </a>

    <div id="detail-loading" class="news-loading">
      <span class="news-spinner" aria-hidden="true"></span>
    </div>

    <div id="detail-error" class="news-empty" hidden>
      <Icon name="newspaper" class="h-7 w-7 text-ink-300" />
      <p>{dict.news.loadError}</p>
    </div>

    <div id="detail-content" hidden></div>
  </section>
</Base>

<style>
  .news-detail { padding-top: 2.5rem; padding-bottom: 4rem; }
  @media (min-width: 768px) { .news-detail { padding-top: 3.5rem; } }

  .news-detail-back {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-size: 13.5px; font-weight: 600; color: var(--color-ink-500);
    text-decoration: none; transition: color 0.18s ease; margin-bottom: 2rem;
  }
  .news-detail-back:hover { color: var(--color-ink-950); }

  .news-detail-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem; margin-bottom: 1rem; }
  .news-detail-cat {
    display: inline-flex; align-items: center; padding: 0.25rem 0.625rem; border-radius: 999px;
    font-size: 11px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;
    background: var(--color-canvas); color: var(--color-ink-700);
  }
  .news-detail-date {
    display: inline-flex; align-items: center; gap: 0.375rem;
    font-size: 13px; color: var(--color-ink-400); font-variant-numeric: tabular-nums;
  }

  .news-detail-title {
    font-size: clamp(1.875rem, 4vw, 2.75rem); font-weight: 600; letter-spacing: -0.025em;
    line-height: 1.1; color: var(--color-ink-950);
  }
  .news-detail-subtitle {
    margin-top: 1rem; font-size: clamp(1.0625rem, 1.6vw, 1.25rem); line-height: 1.55;
    color: var(--color-ink-600);
  }

  .news-detail-hero-img {
    width: 100%; aspect-ratio: 16 / 9; object-fit: cover; border-radius: 16px;
    background: var(--color-canvas); margin-top: 2rem;
  }

  .news-detail-body { margin-top: 2rem; }
  .news-detail-body p {
    font-size: 1.0625rem; line-height: 1.75; color: var(--color-ink-700); margin-bottom: 1.25rem;
  }

  /* === Quote === */
  .news-quote {
    position: relative; margin: 2.5rem 0; padding: 1.75rem 1.75rem 1.75rem 2.5rem;
    border-left: 4px solid var(--color-brand-500);
    background: linear-gradient(180deg, rgba(133, 188, 50, 0.07), rgba(133, 188, 50, 0.02));
    border-radius: 0 14px 14px 0;
    font-size: clamp(1.125rem, 2vw, 1.4rem); font-weight: 500; font-style: italic;
    line-height: 1.5; color: var(--color-ink-900);
  }
  .news-quote::before {
    content: '\201C'; position: absolute; top: -0.5rem; left: 0.75rem;
    font-size: 3rem; line-height: 1; color: var(--color-brand-400); font-family: Georgia, serif;
  }

  /* === Carousel === */
  .news-carousel { margin-top: 2.5rem; }
  .news-carousel-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
  .news-carousel-nav { display: flex; gap: 0.5rem; }
  .news-carousel-btn {
    display: inline-flex; align-items: center; justify-content: center; width: 38px; height: 38px;
    border-radius: 999px; border: 1px solid var(--color-hairline); background: white;
    color: var(--color-ink-700); cursor: pointer; transition: border-color 0.18s ease, color 0.18s ease;
  }
  .news-carousel-btn:hover { border-color: var(--color-edge); color: var(--color-ink-950); }
  .news-carousel-btn:disabled { opacity: 0.35; cursor: not-allowed; }
  .news-carousel-track {
    display: flex; gap: 1rem; overflow-x: auto; scroll-snap-type: x mandatory;
    scroll-behavior: smooth; -webkit-overflow-scrolling: touch; padding-bottom: 0.5rem;
    scrollbar-width: thin;
  }
  .news-carousel-slide {
    flex: 0 0 86%; scroll-snap-align: center; border-radius: 14px; overflow: hidden;
    background: var(--color-canvas);
  }
  @media (min-width: 768px) { .news-carousel-slide { flex-basis: 60%; } }
  .news-carousel-slide img { display: block; width: 100%; aspect-ratio: 16 / 10; object-fit: cover; }

  .news-loading { display: flex; justify-content: center; padding: 3rem 0; }
  .news-spinner {
    width: 28px; height: 28px; border-radius: 50%;
    border: 3px solid var(--color-hairline); border-top-color: var(--color-brand-500);
    animation: news-spin 0.7s linear infinite;
  }
  @keyframes news-spin { to { transform: rotate(360deg); } }
  .news-empty {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 0.75rem; padding: 4rem 1.5rem; background: white; border: 1px dashed var(--color-hairline);
    border-radius: 16px; color: var(--color-ink-500); font-size: 15px;
  }
</style>

<script>
  import { fetchNewsDetail, type PublicNewsDetail } from '~/lib/news.api';

  const HEX6 = /^#([0-9a-f]{6})$/i;
  const CAL_SVG =
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" width="14" height="14"><rect x="3" y="4.5" width="18" height="16" rx="2"/><path d="M3 9h18M8 2.5v4M16 2.5v4" stroke-linecap="round"/></svg>';
  const CHEVRON = (dir: 'left' | 'right') =>
    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="18" height="18"><path d="${dir === 'left' ? 'M15 6l-6 6 6 6' : 'M9 6l6 6-6 6'}" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

  function init() {
    const root = document.getElementById('news-detail-root');
    const loading = document.getElementById('detail-loading');
    const errorEl = document.getElementById('detail-error');
    const content = document.getElementById('detail-content');
    if (!root || !loading || !errorEl || !content) return;

    const lang = root.dataset.lang || 'uz';
    const dateLocale = root.dataset.dateLocale || 'uz-UZ';
    const slug = new URLSearchParams(window.location.search).get('slug');

    if (!slug) {
      loading.hidden = true;
      errorEl.hidden = false;
      return;
    }

    const formatDate = (iso: string) =>
      new Date(iso).toLocaleDateString(dateLocale, { day: 'numeric', month: 'long', year: 'numeric' });

    function render(news: PublicNewsDetail) {
      // Meta (category + date)
      const meta = document.createElement('div');
      meta.className = 'news-detail-meta';
      if (news.categoryName) {
        const cat = document.createElement('span');
        cat.className = 'news-detail-cat';
        cat.textContent = news.categoryName;
        if (news.categoryColor && HEX6.test(news.categoryColor)) {
          cat.style.background = `${news.categoryColor}22`;
          cat.style.color = news.categoryColor;
        }
        meta.appendChild(cat);
      }
      const date = document.createElement('span');
      date.className = 'news-detail-date';
      date.innerHTML = CAL_SVG;
      date.appendChild(document.createTextNode(' ' + formatDate(news.publishedAt)));
      meta.appendChild(date);
      content!.appendChild(meta);

      // Title + subtitle
      const h1 = document.createElement('h1');
      h1.className = 'news-detail-title';
      h1.textContent = news.title;
      content!.appendChild(h1);
      document.title = `${news.title} — IT Park Capital`;

      if (news.subtitle) {
        const sub = document.createElement('p');
        sub.className = 'news-detail-subtitle';
        sub.textContent = news.subtitle;
        content!.appendChild(sub);
      }

      // Main image
      if (news.mainImageUrl) {
        const img = document.createElement('img');
        img.className = 'news-detail-hero-img';
        img.src = news.mainImageUrl;
        img.alt = news.title;
        content!.appendChild(img);
      }

      // Body — split into paragraphs on blank lines
      if (news.body && news.body.trim()) {
        const bodyWrap = document.createElement('div');
        bodyWrap.className = 'news-detail-body';
        news.body
          .split(/\n{2,}/)
          .map(p => p.trim())
          .filter(Boolean)
          .forEach(text => {
            const p = document.createElement('p');
            text.split('\n').forEach((line, i) => {
              if (i > 0) p.appendChild(document.createElement('br'));
              p.appendChild(document.createTextNode(line));
            });
            bodyWrap.appendChild(p);
          });
        content!.appendChild(bodyWrap);
      }

      // Quote
      if (news.quote && news.quote.trim()) {
        const q = document.createElement('blockquote');
        q.className = 'news-quote';
        q.textContent = news.quote;
        content!.appendChild(q);
      }

      // Carousel
      if (news.images && news.images.length) {
        content!.appendChild(buildCarousel(news.images, news.title));
      }
    }

    function buildCarousel(images: string[], alt: string): HTMLElement {
      const wrap = document.createElement('div');
      wrap.className = 'news-carousel';

      const track = document.createElement('div');
      track.className = 'news-carousel-track';
      images.forEach(src => {
        const slide = document.createElement('div');
        slide.className = 'news-carousel-slide';
        const img = document.createElement('img');
        img.src = src;
        img.alt = alt;
        img.loading = 'lazy';
        slide.appendChild(img);
        track.appendChild(slide);
      });

      const scrollByDir = (dir: number) => track.scrollBy({ left: dir * track.clientWidth * 0.7, behavior: 'smooth' });

      if (images.length > 1) {
        const head = document.createElement('div');
        head.className = 'news-carousel-head';
        const nav = document.createElement('div');
        nav.className = 'news-carousel-nav';
        const prev = document.createElement('button');
        prev.type = 'button';
        prev.className = 'news-carousel-btn';
        prev.setAttribute('aria-label', 'Prev');
        prev.innerHTML = CHEVRON('left');
        prev.addEventListener('click', () => scrollByDir(-1));
        const next = document.createElement('button');
        next.type = 'button';
        next.className = 'news-carousel-btn';
        next.setAttribute('aria-label', 'Next');
        next.innerHTML = CHEVRON('right');
        next.addEventListener('click', () => scrollByDir(1));
        nav.append(prev, next);
        head.appendChild(document.createElement('span'));
        head.appendChild(nav);
        wrap.appendChild(head);
      }

      wrap.appendChild(track);
      return wrap;
    }

    fetchNewsDetail(slug, lang)
      .then(news => {
        loading!.hidden = true;
        if (!news) {
          errorEl!.hidden = false;
          return;
        }
        render(news);
        content!.hidden = false;
      })
      .catch(() => {
        loading!.hidden = true;
        errorEl!.hidden = false;
      });
  }

  init();
</script>
