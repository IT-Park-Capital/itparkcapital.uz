---
import type { Locale } from '~/i18n';
import { DEFAULT_LOCATION, buildMapUrl } from '~/lib/location.api';

interface Props {
  locale: Locale;
  dict: ReturnType<typeof import('~/i18n').getDict>;
}

const { locale, dict } = Astro.props;

// Rendered immediately from the built-in coordinates; the client swaps in the
// CMS-managed location once /api/public/location answers.
const defaultMapUrl = buildMapUrl(
  DEFAULT_LOCATION.latitude,
  DEFAULT_LOCATION.longitude,
  DEFAULT_LOCATION.zoom,
);
---

<section class="map-section" id="map-section">
  <div class="container-page">
    <div class="map-card reveal">
      <div class="map-head">
        <span class="map-eyebrow">
          <span class="map-eyebrow-bar" aria-hidden="true"></span>
          {dict.contact.mapTitle}
        </span>
        <span class="map-address" id="map-address">{dict.contact.address}</span>
      </div>
      <div class="map-frame">
        <iframe
          id="map-frame"
          src={defaultMapUrl}
          title={dict.contact.mapTitle}
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ locale }}>
  // Swap in the CMS-managed location (address + coordinates) when available.
  (async () => {
    const { fetchSiteLocation, buildMapUrl } = await import('~/lib/location.api');
    const section = document.getElementById('map-section');
    const frame = document.getElementById('map-frame');
    const addressEl = document.getElementById('map-address');
    if (!section || !frame) return;

    const location = await fetchSiteLocation(locale);
    if (location === undefined) return;                   // backend unreachable → keep defaults
    if (location === null) { section.remove(); return; }  // map switched off in the CMS

    const url = location.mapEmbedUrl
      || buildMapUrl(location.latitude, location.longitude, location.zoom);
    if (url !== frame.getAttribute('src')) frame.setAttribute('src', url);
    if (location.address && addressEl) addressEl.textContent = location.address;
  })();
</script>

<style>
  .map-section {
    padding-top: 3.5rem;
    padding-bottom: 4rem;
  }
  @media (min-width: 768px) {
    .map-section { padding-top: 4.5rem; padding-bottom: 5.5rem; }
  }

  .map-card {
    overflow: hidden;
    border: 1px solid var(--color-hairline);
    border-radius: 20px;
    background: #fff;
    box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04);
  }

  .map-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 1.25rem;
    padding: 1.125rem 1.375rem;
    border-bottom: 1px solid var(--color-hairline);
  }

  .map-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-brand-700);
  }

  .map-eyebrow-bar {
    display: inline-block;
    width: 18px;
    height: 1px;
    background: var(--color-brand-500);
  }

  .map-address {
    font-size: 14px;
    color: var(--color-ink-700);
  }

  .map-frame {
    position: relative;
    height: 320px;
    background: var(--color-canvas);
  }
  @media (min-width: 768px) {
    .map-frame { height: 420px; }
  }

  .map-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
